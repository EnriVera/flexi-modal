{
  "name": "@enrivera/flexi-layer",
  "version": "0.1.0",
  "description": "Accessible, stackable modal/dialog web component built with Lit 3",
  "type": "module",
  "main": "./dist/flexi-layer.umd.js",
  "module": "./dist/flexi-layer.es.js",
  "types": "./dist/flexi-layer.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flexi-layer.es.js",
      "require": "./dist/flexi-layer.umd.js",
      "types": "./dist/flexi-layer.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@open-wc/testing-helpers": "^3.0.0",
    "@playwright/test": "^1.40.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.0.0"
  },
  "repository": "https://github.com/EnriVera/flexi-modal",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  }
}
